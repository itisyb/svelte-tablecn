			"content": "<script lang=\"ts\">\n\timport type { Snippet } from 'svelte';\n\timport type { HTMLAttributes } from 'svelte/elements';\n\timport { cn, type WithElementRef } from '$UTILS$.js';\n\n\tinterface Props extends WithElementRef<HTMLAttributes<HTMLDivElement>, HTMLDivElement> {\n\t\tchildren?: Snippet;\n\t}\n\n\tlet { class: className, children, ref = $bindable(null), ...restProps }: Props = $props();\n</script>\n\n<div\n\tbind:this={ref}\n\tdata-slot=\"grid-skeleton\"\n\tclass={cn(\n\t\t'flex h-[calc(100dvh-(--spacing(16)))] w-full flex-col gap-4 has-[>[data-slot=grid-skeleton-toolbar]]:h-[calc(100dvh-(--spacing(20)))]',\n\t\tclassName\n\t)}\n\t{...restProps}\n>\n\t{@render children?.()}\n</div>\n",
			"type": "registry:component",
			"target": "data-grid/data-grid-skeleton.svelte"
		},
		{
			"content": "<script lang=\"ts\">\n\timport { Skeleton } from '$lib/components/ui/skeleton/index.js';\n\timport { cn, type WithElementRef } from '$UTILS$.js';\n\timport type { HTMLAttributes } from 'svelte/elements';\n\n\tinterface Props extends WithElementRef<HTMLAttributes<HTMLDivElement>, HTMLDivElement> {\n\t\talign?: 'start' | 'center' | 'end';\n\t\tactionCount?: number;\n\t}\n\n\tlet {\n\t\talign = 'end',\n\t\tactionCount = 4,\n\t\tclass: className,\n\t\tref = $bindable(null),\n\t\t...restProps\n\t}: Props = $props();\n\n\tconst actionItems = $derived(Array.from({ length: actionCount }, (_, index) => index));\n</script>\n\n<div\n\tbind:this={ref}\n\tdata-slot=\"grid-skeleton-toolbar\"\n\tclass={cn(\n\t\t'flex items-center gap-2',\n\t\talign === 'start' && 'justify-start',\n\t\talign === 'center' && 'justify-center',\n\t\talign === 'end' && 'justify-end',\n\t\tclassName\n\t)}\n\t{...restProps}\n>\n\t{#each actionItems as action (action)}\n\t\t<Skeleton class=\"h-7 w-20 shrink-0\" />\n\t{/each}\n</div>\n",
			"type": "registry:component",
			"target": "data-grid/data-grid-skeleton-toolbar.svelte"
		},
		{
			"content": "<script lang=\"ts\">\n\timport { Skeleton } from '$lib/components/ui/skeleton/index.js';\n\timport { cn, type WithElementRef } from '$UTILS$.js';\n\timport type { HTMLAttributes } from 'svelte/elements';\n\n\tinterface Props extends WithElementRef<HTMLAttributes<HTMLDivElement>, HTMLDivElement> {}\n\n\tlet { class: className, ref = $bindable(null), ...restProps }: Props = $props();\n</script>\n\n<Skeleton\n\tbind:ref\n\tdata-slot=\"grid-skeleton-grid\"\n\tclass={cn('flex-1', className)}\n\t{...restProps}\n/>\n",
			"type": "registry:component",
			"target": "data-grid/data-grid-skeleton-grid.svelte"
		}
	]
